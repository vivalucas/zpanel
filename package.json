{
  "name": "zpanel",
  "version": "0.0.0",
  "private": false,
  "description": "ZPanel Web",
  "author": "vivalucas",
  "packageManager": "pnpm@11.1.3",
  "keywords": [
    "ZPanel",
    "vue"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-s add-version && run-p type-check build-only",
    "add-version": "node ./scripts/add-frontend-version.js",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "bootstrap": "pnpm install --frozen-lockfile && pnpm run common:prepare",
    "common:cleanup": "rimraf node_modules && rimraf pnpm-lock.yaml",
    "common:prepare": "husky install"
  },
  "dependencies": {
    "@traptitech/markdown-it-katex": "^3.6.0",
    "@vueuse/core": "^14.3.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "markdown-it": "^14.1.1",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-draggable-plus": "^0.2.6",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^17.4.4",
    "@iconify/vue": "^4.1.0",
    "@types/crypto-js": "^4.2.2",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^12.2.3",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.1",
    "eslint": "^10.4.0",
    "husky": "^8.0.3",
    "less": "^4.6.4",
    "lint-staged": "^17.0.5",
    "markdown-it-link-attributes": "^4.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-tsc": "^3.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "pnpm lint:fix"
    ]
  }
}
